<?xml version="1.0"?>
<robot name="auboi5_mujoco_kinematics">
  <link name="base_link"/>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.0435" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.04" upper="3.04" effort="100" velocity="5"/>
  </joint>
  <link name="shoulder_link"/>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 -0.062 0.0785" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.04" upper="3.04" effort="100" velocity="5"/>
  </joint>
  <link name="upper_arm_link"/>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.408" rpy="0 1.1 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.04" upper="3.04" effort="80" velocity="5"/>
  </joint>
  <link name="forearm_link"/>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0 -0.0175 0.376" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.04" upper="3.04" effort="50" velocity="5"/>
  </joint>
  <link name="wrist_1_link"/>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 -0.042 0.06056" rpy="0 0 1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.04" upper="3.04" effort="50" velocity="5"/>
  </joint>
  <link name="wrist_2_link"/>

  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 -0.06056 0.042" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.04" upper="3.04" effort="30" velocity="5"/>
  </joint>
  <link name="wrist_3_link"/>

  <joint name="D435_connector_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="D435_connector_link"/>
    <origin xyz="0 -0.034 0" rpy="1.5708 0 0"/>
  </joint>
  <link name="D435_connector_link"/>

  <joint name="D435_solid_joint" type="fixed">
    <parent link="D435_connector_link"/>
    <child link="D435_solid_link"/>
    <origin xyz="0 0 0.0335" rpy="0 0 1.5708"/>
  </joint>
  <link name="D435_solid_link"/>

  <joint name="tool0_joint" type="fixed">
    <parent link="D435_solid_link"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>
  <link name="tool0"/>
</robot>
